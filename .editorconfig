root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{cs,csx,vb,vbx}]
indent_size = 4

[*.{json,yml,yaml,props,targets,xml,config,csproj,slnx}]
indent_size = 2

[*.{js,jsx,ts,tsx,css,html}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
indent_size = 2

[*.{ps1,sh}]
end_of_line = lf
